# Exclude everything
**

# Include README.md, CHANGELOG.md and LICENSE
!README.md
!CHANGELOG.md
!LICENSE

# Include package.json
!package.json
!package.nls.*

# Include the built extension
!dist

# Include the built webview (CRITICAL: index.html MUST be shipped)
!**/*.map
!webview-ui/audio
!webview-ui/build/index.html
!webview-ui/build/assets/**
!webview-ui/build/sourcemap-manifest.json

# Include default themes JSON files used in getTheme
!integrations/theme/default-themes/**

# Include icons and images
!assets/codicons/**
!assets/vscode-material-icons/**
!assets/icons/**
!assets/images/**

# GLM Frankenstein: include SSB assets (patches, scripts, autostart, MCP bridge)
!assets/ssb/**

# Include .env file for telemetry
!.env
